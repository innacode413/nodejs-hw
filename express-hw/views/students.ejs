<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8">
  <title>Студенти</title>
  <style>
    table { border-collapse: collapse; width: 50%; }
    th, td { border: 1px solid #ccc; padding: 8px; text-align: left; }
    th { background: #f4f4f4; }
  </style>
</head>
<body>
  <h1>Список студентів</h1>
  <table>
    <tr>
      <th>Ім'я</th>
      <th>Рівень</th>
    </tr>
    <% students.forEach(function(s) { %>
      <tr>
        <td><%= s.name %></td>
        <td><%= s.level %></td>
      </tr>
    <% }) %>
  </table>
</body>
</html>
